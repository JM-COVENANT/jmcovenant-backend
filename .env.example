# development | production  (op de server: production)
APP_ENV=development
SECRET_KEY=change-this-in-production
# Optioneel, komma-gescheiden: https://api.jouwdomein.nl
# CORS_EXTRA_ORIGINS=
# Minimale eventlog (data/events.jsonl). 0 = uit. 1 = leesbare e-mail in log (dev).
# EVENT_LOG_ENABLED=1
# EVENT_LOG_PLAIN_EMAIL=0
# EVENT_LOG_PATH=
PORT=5000
FREE_GENERATION_LIMIT=3
FRONTEND_BASE_URL=https://jmcovenant.nl
INTERNAL_API_KEY=change-this-long-random
# Test: sk_test_...  Productie: sk_live_...
STRIPE_SECRET_KEY=sk_test_...
# Live webhook: whsec_... van /billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...